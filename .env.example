# Copy to .env.local and fill in. Do NOT commit real secrets.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/PanditConnect
# Set if Node's DNS resolver can't resolve mongodb+srv SRV records (querySrv ECONNREFUSED)
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# SMTP — leave blank in dev to log emails (and print OTPs) instead of sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="PanditConnect <noreply@example.com>"
SUPPORT_EMAIL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Google OAuth (optional). Redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
NEXT_PUBLIC_GOOGLE_ENABLED=false
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Razorpay — leave blank in dev to offer cash payment only
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=
# Protects /api/cron/* endpoints (Vercel sends it as a Bearer token)
CRON_SECRET=
